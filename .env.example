# Telegram Bot (@BotFather)
BOT_TOKEN=

# https://my.telegram.org — Telethon kullanıcı hesabı
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# İlk çalıştırmada telefon doğrulaması istenir; oturum dosyası oluşur
TELETHON_SESSION_NAME=user_session
# Railway/Docker: dosya oturumu yoksa yerelde "python export_telethon_string_session.py" ile üret ve buraya yapıştır
# TELETHON_STRING_SESSION=

# Ortak grup listesini kaç saniyede bir yenilesin (canlıya yakın)
SYNC_INTERVAL_SEC=45

# Yalnızca bu Telegram kullanıcı ID'si komutları kullanabilir (boş = herkes).
# Davet paketi bekleyen kullanıcı tek seferlik /davet ile link alır (istisna).
ADMIN_USER_ID=

# Yerel web panel (Node) + iç API (Python aiohttp). INTERNAL_PANEL_TOKEN zorunlu.
INTERNAL_API_HOST=127.0.0.1
INTERNAL_API_PORT=18765
INTERNAL_PANEL_TOKEN=
WEB_PANEL_ENABLED=1
# Yerelde 3080; Railway vb. PaaS genelde PORT verir — WEB_PANEL_PORT boşsa PORT kullanılır.
WEB_PANEL_PORT=3080
# Dinleme adresi; Railway’de otomatik 0.0.0.0 (WEB_PANEL_BIND_HOST ile ezilebilir).
# WEB_PANEL_BIND_HOST=0.0.0.0
WEB_PANEL_USER=
# Şifre: düz metin (WEB_PANEL_PASSWORD) veya bcrypt hash (WEB_PANEL_PASSWORD_HASH)
WEB_PANEL_PASSWORD=
WEB_PANEL_PASSWORD_HASH=
# İlk çalıştırmada webpanel/panel_users.json oluşur; sonrasında ek kullanıcılar panelden eklenir.
# WEB_PANEL_USERS_FILE=
# Panel 2FA: her panel kullanıcısı kendi TOTP secret'ını panel_users.json içinde tutar; ilk girişte QR gösterilir.
# Yalnızca tek panel kullanıcısı varken: eski WEB_PANEL_TOTP_SECRET veya panel_totp.secret bir kez o kullanıcıya taşınır.
WEB_PANEL_TOTP_SECRET=
# WEB_PANEL_TOTP_FILE=
# Oturum çerezi; boş bırakılırsa INTERNAL_PANEL_TOKEN üzerinden türetilir.
WEB_PANEL_SESSION_SECRET=

# --- Railway / Docker ---
# Tüm gizli değişkenleri Railway Dashboard → Variables ile girin (.env repoya eklemeyin).
# Railway PORT otomatik verilir; panel ve Python tek konteynerde aynı PORT’a hizalanır.
# Telethon .session dosyası konteyner diskindedir; yeniden deploy’da kaybolabilir — kalıcı volume veya yeniden giriş gerekir.
